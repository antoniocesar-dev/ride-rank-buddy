# Dependencies (always reinstalled in container)
node_modules

# Vite build output (rebuilt inside container)
dist

# Environment files (secrets must not enter build context)
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# Planning and docs (not needed in image)
.planning
*.md
!README.md

# Tests
tests
playwright-fixture.ts
playwright.config.ts
vitest.config.ts
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
src/**/*.test.*
src/**/*.spec.*

# Editor and OS artifacts
.DS_Store
*.swp
*.swo
.idea
.vscode

# Supabase local dev
supabase

# Tools/scripts not needed in image
scripts
tools
pacote-rede
